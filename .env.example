# Copy to backend/.env and fill in. Never commit the real .env.
# Generate a key with:
#   python -c "from django.core.management.utils import get_random_secret_key as k; print(k())"
SECRET_KEY=replace-me

DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Move the control panel off /admin/ in production, e.g. panel-7fa2/
ADMIN_URL=admin/

# SQLite locally; Postgres in production.
# DATABASE_URL=postgres://assembly:password@localhost:5432/assembly
DATABASE_URL=sqlite:///db.sqlite3

# Origins allowed to call the API from a browser. The Next.js app only.
CORS_ALLOWED_ORIGINS=http://localhost:3000
CSRF_TRUSTED_ORIGINS=http://localhost:3000

TIME_ZONE=Asia/Tashkent
LOG_LEVEL=INFO

# Contact form
CONTACT_THROTTLE_RATE=5/hour
CONTACT_NOTIFY_EMAILS=info@assembly.uz

# Email. The console backend just prints to stdout — fine for development.
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
# EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
# EMAIL_HOST=smtp.example.com
# EMAIL_PORT=587
# EMAIL_USE_TLS=True
# EMAIL_HOST_USER=
# EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=noreply@assembly.uz

# Production only
# SECURE_SSL_REDIRECT=True
# SECURE_HSTS_SECONDS=31536000
